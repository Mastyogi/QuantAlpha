# ═══════════════════════════════════════════════════════════════
# QuantAlpha — Complete Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# TRADING MODE  (start with paper, switch to live when ready)
# ─────────────────────────────────────────────────────────────
TRADING_MODE=paper          # paper | live
BROKER_MODE=paper           # paper | mt5  (set mt5 for FxPro live)

# ─────────────────────────────────────────────────────────────
# TELEGRAM
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ADMIN_CHAT_ID=your_telegram_user_id

# ─────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://botuser:changeme123@localhost:5432/trading_bot
DB_PASSWORD=changeme123

# ─────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────
# MT5 / FxPro Direct  (only needed when BROKER_MODE=mt5)
# ─────────────────────────────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=YourMT5Password
MT5_SERVER=FxPro-Demo
# MT5_SERVER=FxPro-Real    # uncomment for real account
MT5_PATH=                  # optional: C:\Program Files\MetaTrader 5\terminal64.exe

# ─────────────────────────────────────────────────────────────
# CRYPTO EXCHANGE (Bitget)
# ─────────────────────────────────────────────────────────────
EXCHANGE_NAME=bitget
BITGET_API_KEY=your_bitget_api_key
BITGET_API_SECRET=your_bitget_secret
BITGET_PASSPHRASE=your_bitget_passphrase

# ─────────────────────────────────────────────────────────────
# TRADING PAIRS
# ─────────────────────────────────────────────────────────────
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT
FOREX_PAIRS=EURUSD,GBPUSD,USDJPY
ENABLE_FOREX=false
ENABLE_CRYPTO=true

# ─────────────────────────────────────────────────────────────
# RISK MANAGEMENT
# ─────────────────────────────────────────────────────────────
INITIAL_EQUITY=10000.00
MAX_RISK_PER_TRADE=2.0
MAX_DAILY_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=15.0
MAX_OPEN_POSITIONS=5
KELLY_FRACTION=0.25

# ─────────────────────────────────────────────────────────────
# BSC ESCROW BRIDGE  (optional — mock mode if not set)
# ─────────────────────────────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_NETWORK=mainnet
ESCROW_CONTRACT_ADDRESS=
USDT_CONTRACT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
BOT_WALLET_PRIVATE_KEY=
SERVICE_WALLET_ADDRESS=
OWNER_WALLET_ADDRESS=

# ─────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-32-random-chars-now
JWT_SECRET_KEY=change-this-jwt-secret-too

# ─────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─────────────────────────────────────────────────────────────
# API SERVER
# ─────────────────────────────────────────────────────────────
API_PORT=8000
WEB_PORT=8080
ENABLE_API_SERVER=true
