# ═══════════════════════════════════════════════════════════════
# QuantAlpha - Self-Improving Portfolio Fund Compounder
# Configuration Template
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# TRADING MODE
# ─────────────────────────────────────────────────────────────
# Options: "paper" (safe testing) | "live" (real money)
TRADING_MODE=paper

# ─────────────────────────────────────────────────────────────
# TELEGRAM BOT CONFIGURATION
# ─────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8619104592:AAEjVGp9eRpphPoP9bhqxMboVf_A-UdXX_M

# Admin chat IDs (comma-separated, get from @userinfobot)
TELEGRAM_ADMIN_CHAT_IDS=7263314996

# Bot name (appears in notifications)
BOT_NAME=QuantAlpha

# ─────────────────────────────────────────────────────────────
# BITGET EXCHANGE CONFIGURATION
# ─────────────────────────────────────────────────────────────
# Get API keys from Bitget account settings
BITGET_API_KEY=bg_24b5d72feb434de76d28b3b97b0a6b52
BITGET_API_SECRET=53caeab8cb8733c84e7c29075911176d32468edf1593505c741412cb8332c30b
BITGET_PASSPHRASE=fixswingproduceclevererasesucces

# Bitget API endpoints
BITGET_API_URL=https://api.bitget.com
BITGET_WS_URL=wss://ws.bitget.com/mix/v1/stream

# Enable Bitget (true/false)
ENABLE_BITGET=true

# ─────────────────────────────────────────────────────────────
# MT5 (MetaTrader 5) CONFIGURATION - For Forex Trading
# ─────────────────────────────────────────────────────────────
# MT5 account credentials
MT5_ACCOUNT=mq99344
MT5_PASSWORD=X9TxNfZV
MT5_SERVER=MetaQuotes-Demo

# MT5 broker (e.g., "ICMarkets-Demo", "FTMO-Demo")
MT5_BROKER=Forex Hedged USD, Floating Leverage

# Enable MT5 (true/false)
ENABLE_MT5=true

# ─────────────────────────────────────────────────────────────
# PORTFOLIO & RISK MANAGEMENT
# ─────────────────────────────────────────────────────────────
# Initial equity (USD)
INITIAL_EQUITY=10000.00

# Kelly Criterion settings
KELLY_FRACTION=0.25
MAX_POSITION_PCT=5.0
MAX_PORTFOLIO_HEAT=12.0

# Risk per trade (%)
MAX_RISK_PER_TRADE=2.0

# Adaptive risk settings
ADAPTIVE_RISK_ENABLED=true
TRACK_LAST_N_TRADES=20

# ─────────────────────────────────────────────────────────────
# COMPOUNDING SETTINGS
# ─────────────────────────────────────────────────────────────
# Enable compounding
ENABLE_COMPOUNDING=true

# Equity change threshold for adjustment (%)
EQUITY_CHANGE_THRESHOLD=10.0

# Minimum position size (% of equity)
MIN_POSITION_SIZE_PCT=0.5

# ─────────────────────────────────────────────────────────────
# PROFIT BOOKING SETTINGS
# ─────────────────────────────────────────────────────────────
# Enable profit booking engine
ENABLE_PROFIT_BOOKING=true

# TP multipliers (based on stop distance)
TP1_MULTIPLIER=1.5
TP2_MULTIPLIER=3.0
TP3_MULTIPLIER=5.0

# Partial close percentages
TP1_CLOSE_PCT=33
TP2_CLOSE_PCT=33
TP3_CLOSE_PCT=34

# Trailing stop settings
TRAILING_STOP_ENABLED=true
TRAILING_STOP_LOCK_PCT=50

# ─────────────────────────────────────────────────────────────
# SIGNAL GENERATION SETTINGS
# ─────────────────────────────────────────────────────────────
# Minimum confluence score (0-100)
MIN_CONFLUENCE_SCORE=75.0

# Minimum AI confidence (0-1)
MIN_AI_CONFIDENCE=0.70

# Enable pattern library
USE_PATTERN_LIBRARY=true

# Pattern boost settings
PATTERN_BOOST_ENABLED=true
MIN_PATTERN_WIN_RATE=0.60

# ─────────────────────────────────────────────────────────────
# SELF-IMPROVEMENT SETTINGS
# ─────────────────────────────────────────────────────────────
# Enable self-improvement engine
ENABLE_SELF_IMPROVEMENT=true

# Analysis intervals (hours)
DAILY_ANALYSIS_INTERVAL=24
WEEKLY_RETRAIN_INTERVAL=168

# Performance thresholds
MIN_WIN_RATE_THRESHOLD=0.55
PRECISION_IMPROVEMENT_THRESHOLD=0.02

# Approval required for model changes
REQUIRE_APPROVAL=true

# ─────────────────────────────────────────────────────────────
# PATTERN DISCOVERY SETTINGS
# ─────────────────────────────────────────────────────────────
# Enable pattern discovery
ENABLE_PATTERN_DISCOVERY=true

# Discovery interval (days)
PATTERN_DISCOVERY_INTERVAL=30

# Minimum pattern thresholds
MIN_PATTERN_WIN_RATE_THRESHOLD=0.60
MIN_PATTERN_PROFIT_FACTOR=1.8
MIN_PATTERN_SHARPE_RATIO=2.0

# Pattern deprecation threshold
PATTERN_DEPRECATION_WIN_RATE=0.58

# ─────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────
# PostgreSQL/TimescaleDB connection
DATABASE_URL=postgresql://user:password@localhost:5432/trading_bot

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─────────────────────────────────────────────────────────────
# ERROR HANDLING & RECOVERY
# ─────────────────────────────────────────────────────────────
# Circuit breaker settings
CIRCUIT_BREAKER_THRESHOLD=10
CIRCUIT_BREAKER_RESET_TIME=300

# Retry settings
MAX_RETRIES=5
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=60.0

# Error buffer size
ERROR_BUFFER_SIZE=1000

# ─────────────────────────────────────────────────────────────
# HEALTH CHECK SETTINGS
# ─────────────────────────────────────────────────────────────
# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=60

# Enable health check alerts
HEALTH_CHECK_ALERTS=true

# ─────────────────────────────────────────────────────────────
# AUDIT & LOGGING
# ─────────────────────────────────────────────────────────────
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=90

# ─────────────────────────────────────────────────────────────
# BACKTESTING SETTINGS
# ─────────────────────────────────────────────────────────────
# Enable backtesting mode
BACKTEST_MODE=false

# Backtest date range
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31

# Backtest initial capital
BACKTEST_INITIAL_CAPITAL=10000.00

# ─────────────────────────────────────────────────────────────
# A/B TESTING SETTINGS
# ─────────────────────────────────────────────────────────────
# Enable A/B testing
ENABLE_AB_TESTING=true

# Test duration (days)
AB_TEST_DURATION=30

# Minimum sample size
AB_TEST_MIN_TRADES=50

# ─────────────────────────────────────────────────────────────
# TRADING PAIRS CONFIGURATION
# ─────────────────────────────────────────────────────────────
# Crypto pairs (comma-separated)
CRYPTO_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT

# Forex pairs (comma-separated)
FOREX_PAIRS=EURUSD,GBPUSD,USDJPY,AUDUSD

# Enable crypto trading
ENABLE_CRYPTO=true

# Enable forex trading
ENABLE_FOREX=true

# ─────────────────────────────────────────────────────────────
# PERFORMANCE OPTIMIZATION
# ─────────────────────────────────────────────────────────────
# Enable Redis caching (requires Redis server)
ENABLE_REDIS_CACHE=false
REDIS_URL=redis://localhost:6379/0

# Cache TTL (seconds)
CACHE_TTL=300

# ─────────────────────────────────────────────────────────────
# API SERVER SETTINGS
# ─────────────────────────────────────────────────────────────
# Enable API server
ENABLE_API_SERVER=true

# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Enable CORS
ENABLE_CORS=true

# ─────────────────────────────────────────────────────────────
# NOTIFICATION SETTINGS
# ─────────────────────────────────────────────────────────────
# Notification preferences
NOTIFY_SIGNAL_GENERATED=true
NOTIFY_TRADE_EXECUTED=true
NOTIFY_TRADE_EXITED=true
NOTIFY_TP_HIT=true
NOTIFY_BREAKEVEN_SET=true
NOTIFY_MODEL_RETRAINED=true
NOTIFY_CIRCUIT_BREAKER=true
NOTIFY_HEALTH_CHANGE=true

# ─────────────────────────────────────────────────────────────
# ADVANCED SETTINGS
# ─────────────────────────────────────────────────────────────
# Model directory
MODEL_DIR=models

# Data directory
DATA_DIR=data

# Logs directory
LOGS_DIR=logs

# Enable debug mode
DEBUG_MODE=false

# Timezone
TIMEZONE=UTC
